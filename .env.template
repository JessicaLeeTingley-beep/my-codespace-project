# EduBuddyBridge Environment Variables Template

# Copy this file to .env and fill in your actual values
# Never commit the .env file with real values to version control

# ============================================
# Azure App Registration Configuration
# ============================================

# Application (Client) ID from Azure App Registration Overview page
MICROSOFT_CLIENT_ID=your_application_client_id_here

# Client Secret Value (NOT the Secret ID) from Certificates & secrets page
MICROSOFT_CLIENT_SECRET=your_client_secret_value_here

# Directory (Tenant) ID from Azure App Registration Overview page
# Can be set to "common" for multi-tenant scenarios
MICROSOFT_TENANT_ID=your_tenant_id_here

# ============================================
# Microsoft Graph API Configuration  
# ============================================

# Microsoft Graph API base URL (usually doesn't need to change)
MICROSOFT_GRAPH_API_URL=https://graph.microsoft.com/v1.0

# OAuth 2.0 endpoints (auto-constructed from tenant ID)
MICROSOFT_OAUTH_AUTHORITY=https://login.microsoftonline.com/${MICROSOFT_TENANT_ID}
MICROSOFT_OAUTH_TOKEN_URL=https://login.microsoftonline.com/${MICROSOFT_TENANT_ID}/oauth2/v2.0/token
MICROSOFT_OAUTH_AUTHORIZE_URL=https://login.microsoftonline.com/${MICROSOFT_TENANT_ID}/oauth2/v2.0/authorize

# ============================================
# Application Configuration
# ============================================

# Redirect URIs (should match what you configured in Azure)
MICROSOFT_REDIRECT_URI_PRODUCTION=https://edubuddybridge.online/api/functions/microsoftEmailIntegration
MICROSOFT_REDIRECT_URI_PREVIEW=https://preview--edubuddybridge.base44.app/api/functions/microsoftEmailIntegration

# Scopes for Microsoft Graph API
MICROSOFT_GRAPH_SCOPES=https://graph.microsoft.com/Mail.Send https://graph.microsoft.com/User.Read

# ============================================
# Optional: Additional Configuration
# ============================================

# Session configuration
SESSION_SECRET=your_session_secret_here
SESSION_TIMEOUT=3600

# Email configuration
DEFAULT_FROM_EMAIL=noreply@edubuddybridge.online
EMAIL_TEMPLATE_PATH=./templates/email

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# Development vs Production
# ============================================

# Environment indicator
NODE_ENV=development

# Base URL for your application
BASE_URL=https://preview--edubuddybridge.base44.app

# Debug mode (set to false in production)
DEBUG_MODE=true

# ============================================
# Example Values (DO NOT USE IN PRODUCTION)
# ============================================

# MICROSOFT_CLIENT_ID=12345678-1234-1234-1234-123456789012
# MICROSOFT_CLIENT_SECRET=abcdefghijklmnopqrstuvwxyz~1234567890ABCDEFGHIJK
# MICROSOFT_TENANT_ID=87654321-4321-4321-4321-210987654321